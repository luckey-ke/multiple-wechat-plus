{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "微信多开助手",
  "version": "1.0.0",
  "identifier": "com.luckeyke.wechat-multi",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "微信多开助手",
        "width": 720,
        "height": 700,
        "minWidth": 600,
        "minHeight": 500,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "portable"],
    "icon": ["icons/icon.png"],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  }
}
